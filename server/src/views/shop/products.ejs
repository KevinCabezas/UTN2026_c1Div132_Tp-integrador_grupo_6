<%- include("../partials/head.ejs") %>
  <main>
    <section>
      <div id="contenedor-productos">


        <!-- Recibimos nuestro array de productos en la plantilla y lo iteramos en la misma plantilla 
                Estamos directamente haciendo la accion del innerHTML -->
        <% productsArray.forEach(producto=> { %>

          <div class="card-producto">
            <img src="<%=producto.image%>" alt="<%=producto.name%>">
            <h4>
              <%=producto.name%>
            </h4>
            <p>Id: <%=producto.id%>
            </p>
            <p>$<%=producto.price%>
            </p>
          </div>

          <% }) %>


      </div>
    </section>
  </main>