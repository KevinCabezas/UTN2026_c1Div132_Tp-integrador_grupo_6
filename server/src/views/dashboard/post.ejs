<%- include("../partials/head.ejs") %>
<%- include("../partials/header.ejs") %>

<div class="layout">
    <%- include("../partials/sidebar.ejs") %>

    <main class="container-secc">
        <section class="form-productos">
            <h2><%= about %></h2>

            <form id="saveProduct-form" class="form-producto">
                <div class="form-group">
                    <label for="name">Nombre:</label>
                    <input type="text" name="name" id="name" required>
                </div>

                <div class="form-group">
                    <label for="brand">Marca:</label>
                    <input type="text" name="brand" id="brand" required>
                </div>

                <div class="form-group">
                    <label for="price">Precio: $</label>
                    <input type="number" name="price" id="price" required>
                </div>

                <div class="form-group">
                    <label for="stock">Stock:</label>
                    <input type="number" name="stock" id="stock" required>
                </div>

                <div class="form-group">
                    <label for="image_url">Imagen (url):</label>
                    <input type="file" name="image" id="image"  accept="image/*" required>
                </div>

                <div class="form-group">
                    <label for="line_id">Línea del Producto:</label>
                    <select name="line_id" id="line_id" required>
                        <option value="" class="line-option">Seleccionar línea</option>
                        <% lineas.forEach(linea => { %>
                            <option value="<%= linea.id %>"><%= linea.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <button type="submit">Crear producto</button>
                </div>
            </form>
        </section>

        <section class="secccion-productos">
            <div id="contenedor-productos"></div>
        </section>
    </main>
</div>

<script src="/js/dashboard/post.js"></script>
<%- include("../partials/footer.ejs") %>